[0.001, "o", "\u001b[38;2;95;135;255m\u001b[H────────────────────────────────────────────────────────────────────────────────\u001b[39m\u001b[2;1H\u001b[K\u001b[38;2;138;190;183m\u001b[1m\r\nContext Injections\u001b(B\u001b[m\u001b[38;2;102;102;102m · \u001b(B\u001b[m\u001b[38;2;240;198;116m\u001b[1m[INITIAL]\u001b(B\u001b[m  \u001b[38;2;102;102;102mRUNTIME\u001b[39m\u001b[K\r\n\u001b[K\u001b[38;2;138;190;183m\r\n→ \u001b[1mpi\u001b(B\u001b[m \u001b[38;2;102;102;102m.......................................\u001b[39m \u001b[38;2;138;190;183m3,433\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m├─ \u001b(B\u001b[m\u001b[38;2;128;128;128mBase Prompt\u001b[39m \u001b[38;2;102;102;102m...........................\u001b[39m \u001b[38;2;128;128;128m605\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m├─ \u001b(B\u001b[m\u001b[38;2;128;128;128mBuilt-in Tools (4)\u001b[39m \u001b[38;2;102;102;102m....................\u001b[39m \u001b[38;2;128;128;128m640\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ edit\u001b[39m \u001b[38;2;102;102;102m...............................\u001b[39m \u001b[38;2;128;128;128m278\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ read\u001b[39m \u001b[38;2;102;102;102m...............................\u001b[39m \u001b[38;2;128;128;128m154\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ bash\u001b[39m \u001b[38;2;102;102;102m...............................\u001b[39m \u001b[38;2;128;128;128m118\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  └─ write\u001b[39m \u001b[38;2;102;102;102m..............................\u001b[39m \u001b[38;2;128;128;128m90\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m├─ \u001b(B\u001b[m\u001b[38;2;128;128;128mSkills (7)\u001b[39m \u001b[38;2;102;102;102m............................\u001b[39m \u001b[38;2;128;128;128m820\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ commit\u001b[39m \u001b[38;2;102;102;102m.............................\u001b[39m \u001b[38;2;128;128;128m152\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ pi-extension\u001b[39m \u001b[38;2;102;102;102m.......................\u001b[39m \u001b[38;2;128;128;128m141\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ skill-creator\u001b[39m \u001b[38;2;102;102;102m......................\u001b[39m \u001b[38;2;128;128;128m137\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ code-style\u001b[39m \u001b[38;2;102;102;102m.........................\u001b[39m \u001b[38;2;128;128;128m116\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ shell-code\u001b[39m \u001b[38;2;102;102;102m.........................\u001b[39m \u001b[38;2;128;128;128m94\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  ├─ typescript-code\u001b[39m \u001b[38;2;102;102;102m....................\u001b[39m \u001b[38;2;128;128;128m93\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m│  └─ python-code\u001b[39m \u001b[38;2;102;102;102m........................\u001b[39m \u001b[38;2;128;128;128m87\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m├─ \u001b(B\u001b[m\u001b[38;2;128;128;128m~/projects/pi-context-view/AGENTS.md\u001b[39m \u001b[38;2;102;102;102m..\u001b[39m \u001b[38;2;128;128;128m1,278\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m└─ \u001b(B\u001b[m\u001b[38;2;128;128;128m~/.pi/agent/AGENTS.md\u001b[39m \u001b[38;2;102;102;102m.................\u001b[39m \u001b[38;2;128;128;128m90\u001b[39m\u001b[K\r\n  \u001b[38;2;212;212;212m\u001b[1mnpm:pi-web-providers\u001b(B\u001b[m \u001b[38;2;102;102;102m.....................\u001b[39m \u001b[38;2;128;128;128m1,510\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m├─ \u001b(B\u001b[m\u001b[38;2;128;128;128mweb_search\u001b[39m \u001b[38;2;102;102;102m............................\u001b[39m \u001b[38;2;128;128;128m1,414\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m└─ \u001b(B\u001b[m\u001b[38;2;128;128;128mweb_contents\u001b[39m \u001b[38;2;102;102;102m..........................\u001b[39m \u001b[38;2;128;128;128m96\u001b[39m\u001b[K\r\n  \u001b[38;2;212;212;212m\u001b[1mnpm:@mrclrchtr/supi-ask-user\u001b(B\u001b[m \u001b[38;2;102;102;102m.............\u001b[39m \u001b[38;2;128;128;128m636\u001b[39m\u001b[K\r\n  \u001b[38;2;102;102;102m└─ \u001b(B\u001b[m\u001b[38;2;128;128;128mask_user\u001b[39m \u001b[38;2;102;102;102m..............................\u001b[39m \u001b[38;2;128;128;128m636\u001b[39m\u001b[K\u001b[38;2;102;102;102m\r\n  (1/22)\u001b[39m\u001b[K\r\n\u001b[K\u001b[38;2;128;128;128m\r\n  Injections into the model context for the first turn, with token estimates.\u001b[39m   \u001b[30;1H\u001b[K\r\n  \u001b[38;2;102;102;102m↑↓\u001b(B\u001b[m\u001b[38;2;128;128;128m Navigate\u001b(B\u001b[m\u001b[38;2;102;102;102m · Enter\u001b(B\u001b[m\u001b[38;2;128;128;128m Preview\u001b(B\u001b[m\u001b[38;2;102;102;102m · Esc\u001b(B\u001b[m\u001b[38;2;128;128;128m Close\u001b[39m\u001b[K\r\n\u001b[K\u001b[38;2;95;135;255m\r\n──────────────────────────────────────────────────────────────────────"]
