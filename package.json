{
	"name": "pi-context-view",
	"version": "0.2.2",
	"description": "Pi extension to visualize context token usage and inspect hidden prompt, tool, and extension injections",
	"type": "module",
	"license": "MIT",
	"author": "Dmitry Makarov",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dimk90/pi-context-view.git"
	},
	"homepage": "https://github.com/dimk90/pi-context-view#readme",
	"bugs": {
		"url": "https://github.com/dimk90/pi-context-view/issues"
	},
	"keywords": [
		"pi",
		"pi-extension",
		"pi-package",
		"coding-agent",
		"context",
		"tokens",
		"tui"
	],
	"engines": {
		"node": ">=22.19.0"
	},
	"files": [
		"src",
		"doc/images",
		"README.md"
	],
	"scripts": {
		"test": "node --test test/*.test.ts",
		"check": "tsc --noEmit && pnpm test"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		],
